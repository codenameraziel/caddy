http://portainer.tailc9398a.ts.net {
    reverse_proxy openclaw-web:8080
    handle_path /ws/* {
        reverse_proxy openclaw-web:3100 {
            transport http {
                compression off
            }
        }
    }
    handle_path /portainer/* {
        reverse_proxy 127.0.0.1:9000
    }
    handle_path /portainer-secure/* {
        reverse_proxy 127.0.0.1:9443
    }
    handle_path /octoprint/* {
        reverse_proxy 127.0.0.1:5000
    }
}
