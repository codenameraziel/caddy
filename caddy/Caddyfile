umbrel.tailc9398a.ts.net {
    # OctoPrint via proxy do Umbrel
    handle_path /octoprint/* {
        reverse_proxy 127.0.0.1:5003
    }

    # OpenClaw direto na raiz
    reverse_proxy openclaw-web:8080

    # WebSocket do OpenClaw
    handle_path /ws/* {
        reverse_proxy openclaw-web:18791
    }
}
