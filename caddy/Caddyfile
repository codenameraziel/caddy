portainer.teccryptor3dprint.dpdns.org {
    tls /etc/caddy/certs/portainer.pem /etc/caddy/certs/portainer.key
    reverse_proxy http://192.168.100.105:9000
    log {
        output file /var/log/caddy/portainer.log
        level INFO
    }
}

