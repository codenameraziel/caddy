# Expor o Umbrel inteiro
umbrel.teccryptor3dprint.dpdns.org {
    reverse_proxy 127.0.0.1:7080 {
        header_up Host {host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# Expor o OctoPrint via Umbrel
octoprint.teccryptor3dprint.dpdns.org {
    reverse_proxy 127.0.0.1:7080 {
        header_up Host {host}
        header_up X-Forwarded-Proto {scheme}
    }
}

